{
  "name": "culin-backend",
  "version": "1.0.0",
  "type": "module",
  "main": "dist/server.js",
  "scripts": {
    "dev": "nodemon --watch src --ext ts,js --exec ts-node-esm src/server.ts",
    
    "start": "node dist/server.js",
    "build:frontend": "cd frontend && npm run build",
    "build:backend": "tsc -p tsconfig.json",
    "build": "npm run build:frontend && npm run build:backend"
  },
  "dependencies": {
    "cors": "^2.8.5",
    "dotenv": "^17.2.3",
    "express": "^4.18.2",
    "mongoose": "^7.0.0"
  },
  "devDependencies": {
    "@types/express": "^4.17.17",
    "@types/node": "^20.8.1",
    "@types/cors": "^2.8.19",
    "nodemon": "^3.1.2",
    "ts-node-esm": "^2.0.12",
    "typescript": "^5.9.3"
  }
}
